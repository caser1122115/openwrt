# 硬件定位 (RAX3000M NAND版最新的 Filogic 适配)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m-nand-mtk=y

# 核心：自动包含所有最新的内核模块
CONFIG_ALL_KMODS=y

# 界面与中文 (追新必备 Argon 皮肤)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_LUCI_LANG_zh_Hans=y

# 核心需求 1：PassWall 2 (最新的分流版本)
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client=y

# 核心需求 2：Tailscale (最新的 Go 语言版本)
CONFIG_PACKAGE_luci-app-tailscale=y

# 高性能优化 (继承 237 大佬的闭源驱动和流控基因)
CONFIG_PACKAGE_luci-app-mtwifi=y
CONFIG_PACKAGE_luci-app-eqos-mtk=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING=y

# 空间优化：NAND版建议剔除不常用包
# CONFIG_PACKAGE_etherwake is not set
# CONFIG_PACKAGE_luci-app-access-control is not set
